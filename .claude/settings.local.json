{
  "language": "chinese",
  "permissions": {
    "allow": [
      "PowerShell(gh *)",
      "PowerShell(git init *)",
      "PowerShell(git *)",
      "PowerShell($oldPath = [Environment]::GetEnvironmentVariable\\(\"Path\", \"User\"\\); $newPath = \"$oldPath;C:\\\\Program Files\\\\GitHub CLI\"; [Environment]::SetEnvironmentVariable\\(\"Path\", $newPath, \"User\"\\))",
      "Bash(export PATH=\"$PATH:/c/Program Files/GitHub CLI:/c/Program Files/Git/cmd\")",
      "Bash(curl -s -H 'Authorization: token __TRACKED_VAR__' https://api.github.com/user)",
      "Bash(curl -s -X POST -H 'Authorization: token __TRACKED_VAR__' -H 'Accept: application/vnd.github.v3+json' https://api.github.com/user/repos -d '{\"name\":\"pomodoro-timer\",\"description\":\"Pomodoro timer with wallpaper support\",\"private\":false}')",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git push *)",
      "Bash(export HTTPS_PROXY=http://127.0.0.1:7897)"
    ]
  }
}
